\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Layer-wise probe ROC-AUC for classifying conflict vs.\ no-conflict items from residual stream activations at \texttt  {P0}{}, restricted to the three vulnerable categories. Llama-3.1-8B-Instruct (blue) peaks at AUC\,=\,0.974 [0.952, 0.992] at L16; R1-Distill-Llama-8B (red) peaks at AUC\,=\,0.930 [0.894, 0.960] at L31---non-overlapping CIs confirm statistical significance. Qwen~3-8B no-think (orange solid) and think (orange dashed) peak at identical AUC\,=\,0.971 at L34---the thinking toggle does not change pre-generation representations. Dashed gray line: Hewitt--Liang control task ceiling.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:probe_curves}{{1}{5}{Layer-wise probe ROC-AUC for classifying conflict vs.\^^Mno-conflict items from residual stream activations at \pzero {}, restricted to the three vulnerable categories. Llama-3.1-8B-Instruct (blue) peaks at AUC\,=\,0.974 [0.952, 0.992] at L16; R1-Distill-Llama-8B (red) peaks at AUC\,=\,0.930 [0.894, 0.960] at L31---non-overlapping CIs confirm statistical significance. Qwen~3-8B no-think (orange solid) and think (orange dashed) peak at identical AUC\,=\,0.971 at L34---the thinking toggle does not change pre-generation representations. Dashed gray line: Hewitt--Liang control task ceiling}{figure.1}{}}
